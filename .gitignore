# all read these as the source of truth for agent capabilities
!.claude/skills/
!.claude/skills/**
dogfood-output/
skills-lock.json
AGENTS.md
CLAUDE.md

# firebase secrets
firebase-secret.json
*firebase-adminsdk*.json
service-account.json

# stitch reference files (source designs, not needed for build)
stitch/
client-secret.json
.env*.local

# Sentry Config File
.env.sentry-build-plugin
functions/node_modules/
scripts/dist/
scripts/crm-backfill-reports/*.csv
.superpowers/
